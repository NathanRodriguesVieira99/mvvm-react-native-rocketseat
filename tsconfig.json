{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@api/*": ["./src/infrastructure/http/*"],
      "@lib/*": ["./src/lib/*"],
      "@stores/*": ["./src/infrastructure/store/*"],
      "@services/*": ["./src/application/services/*"],
      "@presentation/*": ["./src/presentation/*"],
      "@mutations/*": ["./src/infrastructure/mutations/*"],
      "@queries/*": ["./src/infrastructure/queries/*"],
      "@styles/*": ["./src/styles/*"],
      "@assets/*": ["./src/assets/*"],
      "@helpers/*": ["./src/helpers/*"],
      "@screens/*": ["./src/presentation/screens/*"]
    }
  }
}
